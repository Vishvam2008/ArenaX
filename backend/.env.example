# ArenaX Backend Environment Variables (Supabase + Postgres)
# Copy this file to: backend/.env and fill values

# Runtime
NODE_ENV=production
PORT=5000

# Database (Supabase Postgres)
# Use Supabase connection string (URI). If supported/required by your plan, include SSL.
# Example (Supabase): postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# JWT secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# BCrypt
BCRYPT_ROUNDS=12

# CORS
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# Super Admin seed credentials
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=

# Supabase REST API + Storage
# SUPABASE_URL should be your project URL (e.g. https://xxxxxx.supabase.co)
# SUPABASE_SERVICE_KEY should be the "service role" secret
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=arenax-uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Deposit/Withdrawal constraints
MIN_DEPOSIT=10
MAX_DEPOSIT=10000
MIN_WITHDRAWAL=50
MAX_WITHDRAWAL=5000


# =============================================================================
# ArenaX Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# =============================================================================

# ----------------------------
# Server
# ----------------------------
NODE_ENV=development
# Port the HTTP server listens on
PORT=5000

# ----------------------------
# Database (Supabase PostgreSQL)
# ----------------------------
# Full PostgreSQL connection string from Supabase project settings > Database
# Must include ?sslmode=require for Supabase hosted instances
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# ----------------------------
# JWT
# ----------------------------
# Strong random secret for signing access tokens (min 64 chars)
JWT_ACCESS_SECRET=your_super_secret_access_key_minimum_64_characters_long_replace_this_now
# Strong random secret for signing refresh tokens (min 64 chars, DIFFERENT from access)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_64_characters_long_replace_this_now
# Access token expiry (short-lived — 15 minutes recommended)
JWT_ACCESS_EXPIRES=15m
# Refresh token expiry (long-lived — 7 days recommended)
JWT_REFRESH_EXPIRES=7d

# ----------------------------
# Supabase Storage
# ----------------------------
# Your Supabase project URL (found in project settings > API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Supabase service role key (secret — NEVER expose to client side)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Name of the Supabase Storage bucket for all uploads
SUPABASE_STORAGE_BUCKET=arenax-uploads

# ----------------------------
# Security
# ----------------------------
# bcrypt hashing rounds (12 recommended for production; 10 for dev speed)
BCRYPT_ROUNDS=12

# ----------------------------
# CORS
# ----------------------------
# Allowed frontend origin (no trailing slash)
# For multiple origins use comma-separated: https://app.arenax.in,https://admin.arenax.in
CORS_ORIGIN=http://localhost:3000

# ----------------------------
# Rate Limiting
# ----------------------------
# Time window for rate limiting in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests per window per IP
RATE_LIMIT_MAX=100

# ----------------------------
# Super Admin Seed
# Used ONLY by src/config/seed.js — run once after initial migration
# ----------------------------
SUPER_ADMIN_EMAIL=admin@arenax.in
SUPER_ADMIN_USERNAME=superadmin
# IMPORTANT: Change this immediately after first login
SUPER_ADMIN_PASSWORD=ChangeMe@12345!

# ----------------------------
# Wallet Limits (INR)
# ----------------------------
# Minimum deposit amount in INR
MIN_DEPOSIT=10
# Maximum deposit amount in INR
MAX_DEPOSIT=10000
# Minimum withdrawal amount in INR
MIN_WITHDRAWAL=50
# Maximum withdrawal amount in INR
MAX_WITHDRAWAL=5000

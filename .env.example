# ArenaX Payment Server Local Configuration
# Rename this file to .env and configure the variables.

# Port on which the ArenaX payment server runs
ARENAX_PAYMENT_PORT=4400

# Base directory where screenshot folders (Pending, Approved, Rejected) will be stored.
# Supports both relative (e.g. ./Payments) and absolute paths.
ARENAX_PAYMENT_DIR=./Payments

# Maximum allowed file upload size (default: 5MB in bytes)
ARENAX_PAYMENT_MAX_BODY_BYTES=5242880
